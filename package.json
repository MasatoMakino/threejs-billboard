{
  "name": "@masatomakino/threejs-billboard",
  "version": "0.13.0",
  "type": "module",
  "exports": {
    ".": {
      "default": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      }
    }
  },
  "types": "./esm/index.d.ts",
  "files": [
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://MasatoMakino@github.com/MasatoMakino/threejs-billboard.git"
  },
  "author": "MasatoMakino <unagiinu.g@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "pixi.js": "^8.4.0",
    "three": ">=0.126.0 <1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@masatomakino/gulptask-demo-page": "^0.10.0",
    "@types/three": "^0.183.1",
    "@types/webxr": "^0.5.19",
    "@vitest/browser-webdriverio": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "browser-sync": "^3.0.2",
    "lil-gui": "^0.21.0",
    "pixi.js": "^8.9.1",
    "three": "^0.183.1",
    "typedoc": "^0.28.0",
    "typescript": "^5.5.2",
    "webdriverio": "^9.0.1"
  },
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ci": "xvfb-run --auto-servernum vitest --run",
    "coverage": "vitest --run --coverage",
    "coverage:ci": "xvfb-run --auto-servernum vitest --coverage --run",
    "pre-commit": "biome format --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "pre-push": "biome ci . && npm run test:ci",
    "start:dev": "npm run server & npm run watch:tsc & npm run watch:demo",
    "build": "npm run buildTS && npm run demo",
    "demo": "npx @masatomakino/gulptask-demo-page --compileModule es2020",
    "watch:demo": "npm run demo -- -W",
    "buildTS": "tsc",
    "watch:tsc": "tsc -W --incremental",
    "typedocs": "npx typedoc --out ./docs/api src/index.ts",
    "server": "browser-sync ./docs/demo -w --port 3000 --no-open"
  },
  "description": "billboard module for three.js",
  "bugs": {
    "url": "https://github.com/MasatoMakino/threejs-billboard/issues"
  },
  "homepage": "https://github.com/MasatoMakino/threejs-billboard#readme",
  "directories": {
    "doc": "docs",
    "lib": "esm"
  }
}
